#!/usr/bin/env python3
"""display-both — extend the desktop across BOTH the external monitor and the
built-in laptop panel (the external stays primary, laptop placed to its right).

Pairs with ~/display-solo. Talks to GNOME/Mutter directly over D-Bus, so it
re-reads the live state each run (resolution, scale and the changing config
serial) instead of hard-coding anything.
"""
import subprocess, re, sys

DEST = ["--session", "--dest", "org.gnome.Mutter.DisplayConfig",
        "--object-path", "/org/gnome/Mutter/DisplayConfig"]


def gdbus(method, *args):
    return subprocess.run(
        ["gdbus", "call", *DEST,
         "--method", "org.gnome.Mutter.DisplayConfig." + method, *args],
        capture_output=True, text=True)


def state():
    s = gdbus("GetCurrentState").stdout
    if not s:
        sys.exit("Could not reach GNOME's display manager (need a GNOME/Wayland session).")
    serial = re.match(r"\(uint32 (\d+),", s).group(1)
    mons = {}
    for p in s.split("(('"):
        m = re.match(r"([A-Za-z0-9-]+)', ", p)
        if not m:
            continue
        name = m.group(1)
        builtin = "'is-builtin': <true>" in p
        pref = cur = None
        scale = 1.0
        for mm in re.finditer(
                r"'(\d{3,4}x\d{3,4}@[\d.]+(?:\+vrr)?)', \d+, \d+, [\d.]+, ([\d.]+), \[[^\]]*\], \{([^}]*)\}", p):
            mid, psc, props = mm.group(1), float(mm.group(2)), mm.group(3)
            if "'is-preferred': <true>" in props:
                pref, scale = mid, psc
            if "'is-current': <true>" in props:
                cur = mid
        if pref or cur:
            mons[name] = {"builtin": builtin, "mode": cur or pref, "scale": scale}
    for lm in re.finditer(r"\(\d+, \d+, ([\d.]+), uint32 \d+, (?:true|false), \[\('([^']+)'", s):
        if lm.group(2) in mons:
            mons[lm.group(2)]["scale"] = float(lm.group(1))
    return serial, mons


def main():
    serial, mons = state()
    if not mons:
        sys.exit("No displays detected.")
    # external(s) first (so one becomes primary), built-in last, placed to the right
    order = sorted(mons.items(), key=lambda kv: kv[1]["builtin"])
    logical, x, names = [], 0, []
    for i, (name, d) in enumerate(order):
        primary = "true" if i == 0 else "false"
        logical.append(f"({x}, 0, {d['scale']}, uint32 0, {primary}, "
                       f"[('{name}', '{d['mode']}', @a{{sv}} {{}})])")
        names.append(f"{name}@{d['mode']}")
        width = int(round(int(d["mode"].split("x")[0]) / d["scale"]))
        x += width
    cfg = "[" + ", ".join(logical) + "]"
    r = gdbus("ApplyMonitorsConfig", serial, "2", cfg, "@a{sv} {}")
    if r.returncode == 0:
        print("✓ Both displays on (extended): " + ", ".join(names))
    else:
        sys.exit("Failed to apply: " + (r.stderr.strip() or r.stdout.strip()))


if __name__ == "__main__":
    main()
